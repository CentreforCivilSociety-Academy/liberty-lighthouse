# Liberty Lighthouse — environment variables
#
# Copy this file to .env.local and fill in the values you need. .env.local is
# gitignored. Different scripts and workflows read different vars; nothing here
# is required at build time, so you can leave any of them blank if you don't
# need that feature yet.

# OpenRouter API key for wiki regeneration (scripts/ingest/wiki-regen.ts).
# Without this, the wiki step gracefully no-ops and logs a warning. Get one
# at https://openrouter.ai/keys. Set a per-key spending cap there as well.
OPENROUTER_API_KEY=

# Default OpenRouter model for wiki synthesis. Override per-run with
# `npm run ingest:wiki -- --model <slug>`. Bare slug, no `openrouter/` prefix
# (the script calls OpenRouter directly).
OPENROUTER_MODEL=x-ai/grok-4.1-fast
