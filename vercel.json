{
  "headers": [
    {
      "source": "/admin/config.yml",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/yaml; charset=utf-8"
        }
      ]
    }
  ],
  "functions": {
    "api/v1/*.ts": {
      "includeFiles": "src/content/{topics,glossary,faqs,videos}/**"
    }
  }
}
