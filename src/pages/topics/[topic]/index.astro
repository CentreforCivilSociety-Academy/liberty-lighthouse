---
import PageLayout from '../../../layouts/PageLayout.astro';
import TopicHeader from '../../../components/topic/TopicHeader.astro';
import ResourceTabs from '../../../components/topic/ResourceTabs.astro';
import { getAllTopics, getTopicBySlug, getTopicResourceCounts, getFaqsByTopic, getVideosByTopic, getSyllabusByTopic, getSlugFromId, getContentUrl } from '../../../lib/collections';
import Card from '../../../components/ui/Card.astro';
import ContentTypeBadge from '../../../components/ui/ContentTypeBadge.astro';

export async function getStaticPaths() {
  const topics = await getAllTopics();
  return topics.map((topic) => ({
    params: { topic: topic.data.slug },
    props: { topicData: topic.data },
  }));
}

const { topic: topicSlug } = Astro.params;
const { topicData } = Astro.props;
const counts = await getTopicResourceCounts(topicSlug!);
const faqs = await getFaqsByTopic(topicSlug!);
const videos = await getVideosByTopic(topicSlug!);
const syllabus = await getSyllabusByTopic(topicSlug!);
---

<PageLayout title={topicData.title} description={topicData.description}>
  <div class="max-w-[var(--content-max-width)] mx-auto px-[var(--spacing-lg)] py-[var(--spacing-2xl)]">
    <TopicHeader title={topicData.title} description={topicData.description} slug={topicSlug!} />

    <!-- Inline summary of all resource types -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-[var(--spacing-lg)] mb-[var(--spacing-2xl)]">

      {/* FAQ Summary */}
      {faqs.length > 0 && (
        <Card href={`/topics/${topicSlug}/faq/`} class="group">
          <div class="flex items-center gap-[var(--spacing-sm)] mb-[var(--spacing-md)]">
            <ContentTypeBadge type="faq" />
            <span class="text-[0.875rem] text-[var(--color-text-tertiary)]">{faqs.length} questions</span>
          </div>
          <h3 class="text-[1.125rem] font-[600] text-[var(--color-text-primary)] mb-[var(--spacing-sm)] normal-case tracking-normal group-hover:text-[var(--color-primary)] transition-colors" style="font-family: var(--font-display);">
            Frequently Asked Questions
          </h3>
          <ul class="space-y-[var(--spacing-xs)] text-[0.875rem] text-[var(--color-text-secondary)]">
            {faqs.slice(0, 3).map((faq) => (
              <li class="truncate">{faq.data.question}</li>
            ))}
          </ul>
        </Card>
      )}

      {/* Video Summary */}
      {videos.length > 0 && (
        <Card href={`/topics/${topicSlug}/videos/`} class="group">
          <div class="flex items-center gap-[var(--spacing-sm)] mb-[var(--spacing-md)]">
            <ContentTypeBadge type="video" />
            <span class="text-[0.875rem] text-[var(--color-text-tertiary)]">{videos.length} videos</span>
          </div>
          <h3 class="text-[1.125rem] font-[600] text-[var(--color-text-primary)] mb-[var(--spacing-sm)] normal-case tracking-normal group-hover:text-[var(--color-primary)] transition-colors" style="font-family: var(--font-display);">
            Video Curriculum
          </h3>
          <ul class="space-y-[var(--spacing-xs)] text-[0.875rem] text-[var(--color-text-secondary)]">
            {videos.slice(0, 3).map((video) => (
              <li class="truncate">{video.data.title}</li>
            ))}
          </ul>
        </Card>
      )}

      {/* Syllabus Summary */}
      {syllabus.length > 0 && (
        <Card href={`/topics/${topicSlug}/syllabus/`} class="group">
          <div class="flex items-center gap-[var(--spacing-sm)] mb-[var(--spacing-md)]">
            <ContentTypeBadge type="syllabus" />
            <span class="text-[0.875rem] text-[var(--color-text-tertiary)]">{syllabus.length} modules</span>
          </div>
          <h3 class="text-[1.125rem] font-[600] text-[var(--color-text-primary)] mb-[var(--spacing-sm)] normal-case tracking-normal group-hover:text-[var(--color-primary)] transition-colors" style="font-family: var(--font-display);">
            Guided Syllabus
          </h3>
          <ul class="space-y-[var(--spacing-xs)] text-[0.875rem] text-[var(--color-text-secondary)]">
            {syllabus.slice(0, 3).map((mod) => (
              <li class="truncate">Module {mod.data.moduleNumber}: {mod.data.title}</li>
            ))}
          </ul>
        </Card>
      )}

    </div>

    {/* Empty state when no content exists yet */}
    {faqs.length === 0 && videos.length === 0 && syllabus.length === 0 && (
      <div class="text-center py-[var(--spacing-3xl)]">
        <p class="text-[var(--color-text-tertiary)] text-[1.0625rem]">Content for this topic is coming soon.</p>
      </div>
    )}
  </div>
</PageLayout>
