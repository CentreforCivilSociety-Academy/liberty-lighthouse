---
import PageLayout from '../../../../layouts/PageLayout.astro';
import TopicHeader from '../../../../components/topic/TopicHeader.astro';
import ResourceTabs from '../../../../components/topic/ResourceTabs.astro';
import CopyAsMarkdown from '../../../../components/ui/CopyAsMarkdown.astro';
import ChatAboutThis from '../../../../components/ui/ChatAboutThis.astro';
import { getAllTopics, getTopicBySlug, getTopicResourceCounts } from '../../../../lib/collections';
import { buildBreadcrumbSchema } from '../../../../lib/structured-data';
import { marked } from 'marked';

export async function getStaticPaths() {
  const topics = await getAllTopics();
  return topics.map((t) => ({
    params: { topic: t.data.slug },
    props: { topicData: t.data },
  }));
}

const { topic: topicSlug } = Astro.params;
const { topicData } = Astro.props;
const counts = await getTopicResourceCounts(topicSlug!);
const syllabusHtml = topicData.guidedSyllabus ? await marked.parse(topicData.guidedSyllabus) : '';

const pageUrl = Astro.url.href;
const breadcrumbSchema = buildBreadcrumbSchema([
  { name: 'Topics', url: new URL('/topics/', Astro.site).href },
  { name: topicData.title, url: new URL(`/topics/${topicSlug}/`, Astro.site).href },
  { name: 'Syllabus', url: pageUrl },
]);
---

<PageLayout title={`Syllabus — ${topicData.title}`} description={`Guided learning path for ${topicData.title.toLowerCase()} policy in India.`}>
  <div class="max-w-[var(--content-max-width)] mx-auto px-[var(--spacing-lg)] py-[var(--spacing-2xl)]">
    <TopicHeader title={topicData.title} description={topicData.description} slug={topicSlug!} />
    <ResourceTabs topicSlug={topicSlug!} faqCount={counts.faqCount} videoCount={counts.videoCount} hasSyllabus={counts.hasSyllabus} activeTab="syllabus" />

    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

    {syllabusHtml ? (
      <article class="prose mx-auto" data-content-body>
        <h1>{topicData.title} — Guided Syllabus</h1>
        <Fragment set:html={syllabusHtml} />
      </article>
      <div class="max-w-[var(--prose-max-width)] mx-auto mt-[var(--spacing-xl)] flex flex-wrap items-center gap-2 border-t border-[var(--color-border-default)] pt-[var(--spacing-lg)]">
        <CopyAsMarkdown />
        <ChatAboutThis title={`${topicData.title} Guided Syllabus`} contentType="syllabus" excerpt={`Guided learning path for ${topicData.title.toLowerCase()} policy in India.`} />
      </div>
    ) : (
      <p class="text-[var(--color-text-tertiary)] text-center py-[var(--spacing-2xl)]">No guided syllabus available yet.</p>
    )}
  </div>
</PageLayout>
