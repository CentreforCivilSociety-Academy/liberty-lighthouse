                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="ai-status-spin text-[#f5b54a]">
                  <path d="M21 12a9 9 0 1 1-6.219-8.56"/>
                </svg>
              )}
            </div>
            <div class="flex-1 min-w-0">
              <div class="flex items-baseline gap-[var(--spacing-sm)] mb-[0.25rem] flex-wrap">
                <span class="text-[0.6875rem] font-[700] uppercase tracking-[0.12em] opacity-50" style="font-family: var(--font-body);">{item.phase}</span>
