        <p class="text-[0.875rem]" style="font-family: var(--font-body);"><a href="/privacy/" class="text-[var(--color-accent-text)] underline decoration-[var(--color-accent)]/40 hover:decoration-[var(--color-accent)]">Privacy policy →</a></p>
