---
import PageLayout from '../layouts/PageLayout.astro';
import Breadcrumbs from '../components/global/Breadcrumbs.astro';

const MCP_URL = 'https://liberty-lighthouse.vercel.app/api/v1/mcp';

const statusItems: Array<{
  phase: string;
  label: string;
  state: 'live' | 'planned' | 'next' | 'in_progress';
  note: string;
}> = [
  {
    phase: 'Phase 1',
    label: 'BM25 search core',
    state: 'live',
    note: '1,148 docs indexed across topics, FAQs, videos, glossary, wiki, Spontaneous Order, CCS Books.',
  },
  {
    phase: 'Phase 2',
    label: 'Public HTTP API',
    state: 'live',
    note: '/api/v1/{index,search,fetch,glossary,topics} — anonymous, CORS-open, cited responses.',
  },
  {
    phase: 'Phase 3',
    label: 'Streamable HTTP MCP',
    state: 'live',
    note: 'POST /api/v1/mcp — five tools, stateless serverless, ready for any MCP client.',
  },
  {
    phase: 'Eval track',
    label: 'Answer-quality evals',
    state: 'in_progress',
    note: 'A rolling test suite that asks the API canonical policy questions and checks the citations come back correct. Catches retrieval and citation regressions before they ship.',
  },
  {
    phase: 'Phase 4',
    label: 'OpenAPI spec + ChatGPT Action',
    state: 'next',
    note: 'BM25-backed Custom GPT (the existing browsing-based GPT works today).',
  },
  {
    phase: 'Phase 5',
    label: 'This /ai page',
    state: 'live',
    note: 'You are here.',
  },
  {
    phase: 'Phase 6+',
    label: 'Telemetry, admin dashboard, listings',
    state: 'planned',
    note: 'Anonymous usage stats; submission to claude.com/connectors and the GPT Store.',
  },
];

const tools: Array<{
  name: string;
  blurb: string;
}> = [
  { name: 'read_index', blurb: 'Curated index, schema, and corpus summary. Always call first.' },
  { name: 'search', blurb: 'BM25 over the full corpus. Returns ranked hits with snippets and citations.' },
  { name: 'fetch', blurb: 'Markdown body of any page on the site, with frontmatter parsed into a citation.' },
  { name: 'list_glossary', blurb: 'Enumerate terms with short definitions. Optional substring filter.' },
  { name: 'list_topics', blurb: 'Top-level policy topics with FAQ + video counts.' },
];
---

<PageLayout
  title="AI/MCP access — Liberty Lighthouse"
  description="Plug Liberty Lighthouse into ChatGPT, Claude, Cursor, or any MCP client. Public, anonymous, citation-grounded. Built on Karpathy's LLM Wiki pattern."
>
  <!-- HERO -->
  <section class="ai-hero relative bg-[var(--color-bg-dark)] overflow-hidden">
    <div class="absolute inset-0 opacity-[0.03]" style="background-image: url('data:image/svg+xml,%3Csvg viewBox=%220 0 256 256%22 xmlns=%22http://www.w3.org/2000/svg%22%3E%3Cfilter id=%22noise%22%3E%3CfeTurbulence type=%22fractalNoise%22 baseFrequency=%220.9%22 numOctaves=%224%22 stitchTiles=%22stitch%22/%3E%3C/filter%3E%3Crect width=%22100%25%22 height=%22100%25%22 filter=%22url(%23noise)%22/%3E%3C/svg%3E'); background-size: 256px 256px;"></div>
    <div class="ai-horizon absolute bottom-0 left-0 right-0 h-[55%] pointer-events-none" aria-hidden="true"></div>

    <div class="relative z-10 max-w-[var(--content-max-width)] mx-auto px-[var(--spacing-lg)] py-[var(--spacing-2xl)] md:py-[3.5rem]">
      <div class="max-w-[56rem] mx-auto text-center">
        <p class="text-[0.75rem] md:text-[0.8125rem] font-[600] uppercase tracking-[0.18em] text-[var(--color-accent)] mb-[var(--spacing-lg)] fade-up"
           style="font-family: var(--font-body);">
          For Agents · For LLMs · For Researchers
        </p>

        <h1
          class="font-[800] tracking-[-0.025em] leading-[1.05] text-[var(--color-text-on-dark)] mb-[var(--spacing-xl)] fade-up fade-up-delay-1"
          style="font-family: var(--font-display); font-optical-sizing: auto; text-wrap: balance; font-size: clamp(2rem, calc(4vw + 1.5rem), 4rem);"
        >
          The corpus,<br/><em class="not-italic" style="color: var(--color-accent);">readable by your AI.</em>
        </h1>

        <div class="flex items-center justify-center gap-[0.75rem] mb-[var(--spacing-xl)] fade-up fade-up-delay-1" aria-hidden="true">
          <span class="ai-rule-line block h-[1px] w-[3.5rem] md:w-[5rem] bg-[var(--color-accent)] origin-left"></span>
          <span class="block w-[5px] h-[5px] rotate-45 bg-[var(--color-accent)] opacity-80"></span>
          <span class="ai-rule-line block h-[1px] w-[3.5rem] md:w-[5rem] bg-[var(--color-accent)] origin-right"></span>
        </div>

        <p class="text-[1.0625rem] md:text-[1.1875rem] text-[var(--color-text-on-dark)] opacity-65 leading-[1.7] mb-[var(--spacing-xl)] max-w-[42rem] mx-auto fade-up fade-up-delay-2"
           style="font-family: var(--font-body); text-wrap: pretty;">
          Use Liberty Lighthouse from inside whichever AI tool you already have open. There's no signup or API key, and every answer carries a URL back to the page it cited.
        </p>

        <!-- MCP URL pill -->
        <div class="fade-up fade-up-delay-3 inline-flex items-center gap-[0.625rem] px-[1rem] py-[0.625rem] rounded-full border border-[var(--color-accent)]/30 bg-[var(--color-accent)]/[0.08] backdrop-blur-sm">
          <span class="inline-block w-[7px] h-[7px] rounded-full bg-[#5dd39e] shadow-[0_0_8px_rgba(93,211,158,0.6)] animate-pulse"></span>
          <span class="text-[0.875rem] font-[600] text-[var(--color-accent)] uppercase tracking-[0.1em]" style="font-family: var(--font-body);">Live</span>
          <span class="block w-px h-4 bg-[var(--color-text-on-dark)]/20"></span>
          <code class="text-[0.8125rem] md:text-[0.9375rem] text-[var(--color-text-on-dark)]/85 select-all" style="font-family: var(--monospace-font, ui-monospace, monospace);">{MCP_URL}</code>
        </div>
      </div>
    </div>
  </section>

  <!-- BREADCRUMBS + MD ACTIONS -->
  <div class="max-w-[var(--content-max-width)] mx-auto px-[var(--spacing-lg)] pt-[var(--spacing-lg)] flex items-center justify-between gap-[var(--spacing-md)] flex-wrap">
    <Breadcrumbs items={[{ label: 'AI/MCP access' }]} />
    <div data-ai-md-actions class="flex items-center gap-[var(--spacing-sm)] text-[0.8125rem]" style="font-family: var(--font-body);">
      <a
        href="/ai.md"
        class="inline-flex items-center gap-[0.375rem] px-[0.625rem] py-[0.375rem] rounded-[6px] border border-[var(--color-border-subtle)] text-[var(--color-text-secondary)] hover:text-[var(--color-primary)] hover:border-[var(--color-accent)] transition-colors no-underline"
      >
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
          <polyline points="14 2 14 8 20 8"/>
        </svg>
        View as Markdown
      </a>
      <button
        type="button"
        data-md-copy
        class="inline-flex items-center gap-[0.375rem] px-[0.625rem] py-[0.375rem] rounded-[6px] border border-[var(--color-border-subtle)] text-[var(--color-text-secondary)] hover:text-[var(--color-primary)] hover:border-[var(--color-accent)] transition-colors bg-transparent cursor-pointer"
      >
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect x="9" y="9" width="13" height="13" rx="2" ry="2"/>
          <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>
        </svg>
        <span data-md-copy-label>Copy</span>
      </button>
    </div>
  </div>

  <!-- INTEGRATIONS -->
  <section class="max-w-[var(--content-max-width)] mx-auto px-[var(--spacing-lg)] py-[var(--spacing-2xl)]">
    <header class="max-w-[44rem] mb-[var(--spacing-2xl)]">
      <p class="text-[0.75rem] font-[600] uppercase tracking-[0.16em] text-[var(--color-accent-text)] mb-[var(--spacing-md)]" style="font-family: var(--font-body);">Use it with</p>
      <h2 class="font-[700] tracking-[-0.02em] leading-[1.15] text-[var(--color-text-primary)] mb-[var(--spacing-md)]"
          style="font-family: var(--font-display); font-size: clamp(1.75rem, calc(2vw + 1.25rem), 2.5rem);">
        Pick whichever fits your tool.
      </h2>
      <p class="text-[1rem] md:text-[1.0625rem] text-[var(--color-text-secondary)] leading-[1.7]" style="font-family: var(--font-body);">
        It's the same endpoint underneath. What changes is the setup.
      </p>
    </header>

    <div class="grid gap-[var(--spacing-lg)] md:grid-cols-2 lg:grid-cols-3">

      <!-- Card: claude.ai -->
      <article class="ai-card relative bg-[var(--color-bg-card)] border border-[var(--color-border-default)] rounded-[12px] p-[var(--spacing-xl)] transition-all duration-300">
        <div class="ai-card-icon mb-[var(--spacing-md)]">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" class="text-[var(--color-accent)]" aria-hidden="true">
            <rect x="3" y="3" width="18" height="18" rx="3"/>
            <path d="m9 12 2 2 4-4"/>
          </svg>
        </div>
        <h3 class="text-[1.125rem] font-[700] text-[var(--color-text-primary)] mb-[0.375rem]" style="font-family: var(--font-display);">claude.ai</h3>
        <p class="text-[0.875rem] text-[var(--color-text-tertiary)] mb-[var(--spacing-md)] uppercase tracking-[0.08em]" style="font-family: var(--font-body);">Pro · Team · Max · Enterprise</p>
        <ol class="text-[0.9375rem] text-[var(--color-text-secondary)] leading-[1.65] space-y-[0.375rem] mb-[var(--spacing-md)]">
          <li>1. Settings → Connectors → <em>Add custom</em></li>
          <li>2. Paste the URL above. Auth: <em>none</em>.</li>
          <li>3. Save and start asking.</li>
        </ol>
        <p class="text-[0.875rem] text-[var(--color-text-tertiary)] italic" style="font-family: var(--font-body);">"What does CCS think about MSP?" — Claude composes <code>read_index → search → fetch</code>.</p>
      </article>

      <!-- Card: Claude skill (no connector) -->
      <article class="ai-card relative bg-[var(--color-bg-card)] border border-[var(--color-border-default)] rounded-[12px] p-[var(--spacing-xl)] transition-all duration-300">
        <div class="ai-card-icon mb-[var(--spacing-md)]">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" class="text-[var(--color-accent)]" aria-hidden="true">
            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
            <polyline points="14 2 14 8 20 8"/>
            <line x1="9" y1="13" x2="15" y2="13"/>
            <line x1="9" y1="17" x2="15" y2="17"/>
          </svg>
        </div>
        <h3 class="text-[1.125rem] font-[700] text-[var(--color-text-primary)] mb-[0.375rem]" style="font-family: var(--font-display);">Claude skill (no connector)</h3>
        <p class="text-[0.875rem] text-[var(--color-text-tertiary)] mb-[var(--spacing-md)] uppercase tracking-[0.08em]" style="font-family: var(--font-body);">Free · Pro · Any tier with web fetch</p>
        <ol class="text-[0.9375rem] text-[var(--color-text-secondary)] leading-[1.65] space-y-[0.375rem] mb-[var(--spacing-md)]">
          <li>1. Save <a href="/SKILL.md" class="underline decoration-[var(--color-accent)]/40 hover:decoration-[var(--color-accent)]"><code>/SKILL.md</code></a> to disk.</li>
          <li>2. Upload as a personal skill on claude.ai, or drop it in <code>.claude/skills/</code>.</li>
          <li>3. Ask anything about Indian policy.</li>
        </ol>
        <p class="text-[0.875rem] text-[var(--color-text-tertiary)] italic" style="font-family: var(--font-body);">Wraps the same HTTP API. No connector, no MCP client, no setup beyond the upload.</p>
      </article>

      <!-- Card: Claude Desktop / Cursor / Cline -->
      <article class="ai-card relative bg-[var(--color-bg-card)] border border-[var(--color-border-default)] rounded-[12px] p-[var(--spacing-xl)] transition-all duration-300">
        <div class="ai-card-icon mb-[var(--spacing-md)]">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" class="text-[var(--color-accent)]" aria-hidden="true">
            <polyline points="16 18 22 12 16 6"/>
            <polyline points="8 6 2 12 8 18"/>
          </svg>
        </div>
        <h3 class="text-[1.125rem] font-[700] text-[var(--color-text-primary)] mb-[0.375rem]" style="font-family: var(--font-display);">Claude Desktop · Cursor · Cline · Continue</h3>
        <p class="text-[0.875rem] text-[var(--color-text-tertiary)] mb-[var(--spacing-md)] uppercase tracking-[0.08em]" style="font-family: var(--font-body);">JSON config</p>
        <pre class="text-[0.75rem] bg-[var(--color-bg-section)] border border-[var(--color-border-subtle)] rounded-[6px] p-[0.75rem] overflow-x-auto leading-[1.5] mb-[var(--spacing-md)]" style="font-family: var(--monospace-font, ui-monospace, monospace);"><code>{`"liberty-lighthouse": {
  "transport": "http",
  "url": "${MCP_URL}"
}`}</code></pre>
        <p class="text-[0.875rem] text-[var(--color-text-tertiary)] italic" style="font-family: var(--font-body);">Add inside <code>mcpServers</code>. Restart the client. Five tools appear.</p>
      </article>

      <!-- Card: MCP Inspector -->
      <article class="ai-card relative bg-[var(--color-bg-card)] border border-[var(--color-border-default)] rounded-[12px] p-[var(--spacing-xl)] transition-all duration-300">
        <div class="ai-card-icon mb-[var(--spacing-md)]">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" class="text-[var(--color-accent)]" aria-hidden="true">
            <circle cx="11" cy="11" r="8"/>
            <path d="m21 21-4.3-4.3"/>
          </svg>
        </div>
        <h3 class="text-[1.125rem] font-[700] text-[var(--color-text-primary)] mb-[0.375rem]" style="font-family: var(--font-display);">MCP Inspector</h3>
        <p class="text-[0.875rem] text-[var(--color-text-tertiary)] mb-[var(--spacing-md)] uppercase tracking-[0.08em]" style="font-family: var(--font-body);">Quickest sanity check · 2 min</p>
        <pre class="text-[0.75rem] bg-[var(--color-bg-section)] border border-[var(--color-border-subtle)] rounded-[6px] p-[0.75rem] overflow-x-auto leading-[1.5] mb-[var(--spacing-md)]" style="font-family: var(--monospace-font, ui-monospace, monospace);"><code>npx @modelcontextprotocol/inspector \
  {MCP_URL}</code></pre>
        <p class="text-[0.875rem] text-[var(--color-text-tertiary)] italic" style="font-family: var(--font-body);">Browser UI lists all five tools. Click, fill, run. No setup needed.</p>
      </article>

      <!-- Card: ChatGPT (browsing-based) -->
      <article class="ai-card relative bg-[var(--color-bg-card)] border border-[var(--color-border-default)] rounded-[12px] p-[var(--spacing-xl)] transition-all duration-300">
        <div class="ai-card-icon mb-[var(--spacing-md)]">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" class="text-[var(--color-accent)]" aria-hidden="true">
            <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
          </svg>
        </div>
        <h3 class="text-[1.125rem] font-[700] text-[var(--color-text-primary)] mb-[0.375rem]" style="font-family: var(--font-display);">ChatGPT</h3>
        <p class="text-[0.875rem] text-[var(--color-text-tertiary)] mb-[var(--spacing-md)] uppercase tracking-[0.08em]" style="font-family: var(--font-body);">Plus · Custom GPT (browsing-based)</p>
        <p class="text-[0.9375rem] text-[var(--color-text-secondary)] leading-[1.65] mb-[var(--spacing-md)]">Build a Custom GPT that fetches our <code>.md</code> URLs directly via ChatGPT's web browsing capability. Setup checklist in the repo.</p>
        <p class="text-[0.875rem] text-[var(--color-text-tertiary)] italic mb-[var(--spacing-sm)]" style="font-family: var(--font-body);">An Action-based variant calling our BM25 endpoints is on the roadmap (Phase 4).</p>
        <a href="https://github.com/CentreforCivilSociety-Academy/liberty-lighthouse/blob/main/docs/distribution/custom-gpt.md" class="text-[0.875rem] text-[var(--color-accent-text)] underline decoration-[var(--color-accent)]/40 hover:decoration-[var(--color-accent)] transition-colors">Setup checklist →</a>
      </article>

      <!-- Card: Raw HTTP / build your own -->
      <article class="ai-card relative bg-[var(--color-bg-card)] border border-[var(--color-border-default)] rounded-[12px] p-[var(--spacing-xl)] transition-all duration-300">
        <div class="ai-card-icon mb-[var(--spacing-md)]">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" class="text-[var(--color-accent)]" aria-hidden="true">
            <polyline points="4 17 10 11 4 5"/>
            <line x1="12" y1="19" x2="20" y2="19"/>
          </svg>
        </div>
        <h3 class="text-[1.125rem] font-[700] text-[var(--color-text-primary)] mb-[0.375rem]" style="font-family: var(--font-display);">Raw HTTP</h3>
        <p class="text-[0.875rem] text-[var(--color-text-tertiary)] mb-[var(--spacing-md)] uppercase tracking-[0.08em]" style="font-family: var(--font-body);">curl · fetch · whatever</p>
        <pre class="text-[0.75rem] bg-[var(--color-bg-section)] border border-[var(--color-border-subtle)] rounded-[6px] p-[0.75rem] overflow-x-auto leading-[1.5] mb-[var(--spacing-md)]" style="font-family: var(--monospace-font, ui-monospace, monospace);"><code>GET /api/v1/search?q=msp
GET /api/v1/fetch?url=…
GET /api/v1/index</code></pre>
        <p class="text-[0.875rem] text-[var(--color-text-tertiary)] italic" style="font-family: var(--font-body);">Anonymous, CORS-open, JSON, citation blocks on every response.</p>
      </article>

      <!-- Card: llms.txt / static markdown -->
      <article class="ai-card relative bg-[var(--color-bg-card)] border border-[var(--color-border-default)] rounded-[12px] p-[var(--spacing-xl)] transition-all duration-300">
        <div class="ai-card-icon mb-[var(--spacing-md)]">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" class="text-[var(--color-accent)]" aria-hidden="true">
            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
            <polyline points="14 2 14 8 20 8"/>
          </svg>
        </div>
        <h3 class="text-[1.125rem] font-[700] text-[var(--color-text-primary)] mb-[0.375rem]" style="font-family: var(--font-display);">Anything that reads <code>llms.txt</code></h3>
        <p class="text-[0.875rem] text-[var(--color-text-tertiary)] mb-[var(--spacing-md)] uppercase tracking-[0.08em]" style="font-family: var(--font-body);">Crawlers · Skills · Static fetchers</p>
        <p class="text-[0.9375rem] text-[var(--color-text-secondary)] leading-[1.65] mb-[var(--spacing-md)]">Every public page has a markdown sibling. Append <code>.md</code> to any URL. Howard-spec index at <a href="/llms.txt" class="underline decoration-[var(--color-accent)]/40 hover:decoration-[var(--color-accent)]">/llms.txt</a>; full corpus dump at <a href="/llms-full.txt" class="underline decoration-[var(--color-accent)]/40 hover:decoration-[var(--color-accent)]">/llms-full.txt</a>.</p>
        <p class="text-[0.875rem] text-[var(--color-text-tertiary)] italic" style="font-family: var(--font-body);">Schema and citation rules at <a href="/AGENTS.md" class="underline decoration-[var(--color-accent)]/40 hover:decoration-[var(--color-accent)]">/AGENTS.md</a>.</p>
      </article>

    </div>
  </section>

  <!-- TOOLS -->
  <section class="bg-[var(--color-bg-section)] border-y border-[var(--color-border-subtle)]">
    <div class="max-w-[var(--content-max-width)] mx-auto px-[var(--spacing-lg)] py-[var(--spacing-2xl)]">
      <header class="max-w-[44rem] mb-[var(--spacing-2xl)]">
        <p class="text-[0.75rem] font-[600] uppercase tracking-[0.16em] text-[var(--color-accent-text)] mb-[var(--spacing-md)]" style="font-family: var(--font-body);">The five tools</p>
        <h2 class="font-[700] tracking-[-0.02em] leading-[1.15] text-[var(--color-text-primary)] mb-[var(--spacing-md)]"
            style="font-family: var(--font-display); font-size: clamp(1.75rem, calc(2vw + 1.25rem), 2.5rem);">
          Five small tools.
        </h2>
        <p class="text-[1rem] md:text-[1.0625rem] text-[var(--color-text-secondary)] leading-[1.7]" style="font-family: var(--font-body);">
          They're meant to compose. The agent picks the order; every result comes back with a citation block attached.
        </p>
      </header>

      <div class="grid gap-[var(--spacing-md)] md:grid-cols-2">
        {tools.map((t) => (
          <div class="flex items-baseline gap-[var(--spacing-md)] py-[var(--spacing-md)] border-b border-[var(--color-border-subtle)]/60 last:border-b-0">
            <code class="text-[0.9375rem] font-[700] text-[var(--color-primary)] flex-shrink-0" style="font-family: var(--monospace-font, ui-monospace, monospace);">{t.name}</code>
            <p class="text-[0.9375rem] text-[var(--color-text-secondary)] leading-[1.65]" style="font-family: var(--font-body);">{t.blurb}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- METHODOLOGY -->
  <section class="max-w-[var(--content-max-width)] mx-auto px-[var(--spacing-lg)] py-[var(--spacing-2xl)]">
    <header class="max-w-[44rem] mb-[var(--spacing-2xl)]">
      <p class="text-[0.75rem] font-[600] uppercase tracking-[0.16em] text-[var(--color-accent-text)] mb-[var(--spacing-md)]" style="font-family: var(--font-body);">Methodology</p>
      <h2 class="font-[700] tracking-[-0.02em] leading-[1.15] text-[var(--color-text-primary)] mb-[var(--spacing-md)]"
          style="font-family: var(--font-display); font-size: clamp(1.75rem, calc(2vw + 1.25rem), 2.5rem);">
        A markdown corpus and a BM25 index.<br/><span class="text-[var(--color-text-secondary)]">The model that calls the API does the rest.</span>
      </h2>
      <p class="text-[0.9375rem] text-[var(--color-text-tertiary)] leading-[1.6]" style="font-family: var(--font-body);">
        by <a href="https://meetadnan.com" class="text-[var(--color-accent-text)] underline decoration-[var(--color-accent)]/40 hover:decoration-[var(--color-accent)]">Adnan Abbasi</a> · <a href="https://github.com/adoistic" class="text-[var(--color-accent-text)] underline decoration-[var(--color-accent)]/40 hover:decoration-[var(--color-accent)]">github.com/adoistic</a>
      </p>
    </header>

    <div class="prose max-w-[44rem] mx-auto md:mx-0">
      <p>
        The setup is unfashionable. The corpus is plain markdown in a git repository. A build job tokenizes it into a BM25 index, which is a JSON blob the API loads into memory on cold start. There's no vector store and no retrieval pipeline. When a search call comes in, BM25 picks the candidates; the model that asked does the rest of the thinking.
      </p>

      <p>
        That choice came from reading Karpathy on what he calls the LLM Wiki pattern.
      </p>

      <blockquote class="ai-pullquote my-[var(--spacing-xl)] py-[var(--spacing-lg)] px-[var(--spacing-xl)] border-l-[3px] border-[var(--color-accent)]/60 bg-[var(--color-bg-elevated)]">
        <p class="text-[1.0625rem] md:text-[1.1875rem] leading-[1.6] text-[var(--color-text-primary)] italic mb-[var(--spacing-sm)]" style="font-family: var(--font-display);">
          "Treat the LLM as a compiler that reads raw source documents and produces a structured, interlinked wiki. Don't rely on complex RAG pipelines or vector databases."
        </p>
        <footer class="text-[0.875rem] text-[var(--color-text-tertiary)] not-italic" style="font-family: var(--font-body);">
          — Andrej Karpathy, on the <a href="https://gist.github.com/karpathy/442a6bf555914893e9891c11519de94f" class="underline decoration-[var(--color-accent)]/40 hover:decoration-[var(--color-accent)]">LLM Wiki pattern</a>
        </footer>
      </blockquote>

      <p>
        His point: an embedding is opaque. You can't read it, and when retrieval surfaces the wrong page you can't really say why. A markdown file isn't opaque. If an answer cites <code>/glossary/msp.md</code>, you open the file and see exactly what the model was reading.
      </p>

      <p>
        The scale rule he gives is roughly: under a few hundred pages, an <code>llms.txt</code> index by itself is enough. Past that, add BM25. Only reach for vectors when BM25 starts missing things. The corpus is around 1,150 documents, so I'm at the BM25 step, and I haven't hit a recall problem yet.
      </p>

      <h3>A pattern, applied twice: <span style="color: var(--color-accent);">falsafa.ai</span></h3>

      <p>
        I built <a href="https://falsafa.ai" class="underline decoration-[var(--color-accent)]/40 hover:decoration-[var(--color-accent)]">falsafa.ai</a> (<a href="https://github.com/adoistic/falsafa" class="underline decoration-[var(--color-accent)]/40 hover:decoration-[var(--color-accent)]">source</a>) before this. Same setup, applied to classical and philosophical works: markdown as the source, three small read tools (<code>search_corpus</code>, <code>read_chapter</code>, <code>get_passage</code>), a synthesised wiki layer for navigation, and citation handles that take you back to the original passage. Liberty Lighthouse is that pattern run again on a different body of text.
      </p>

      <p>
        Repeating the pattern is the point. The texts don't transfer. Philosophy and Indian policy aren't comparable subjects. But the shape of the work is the same: bounded bodies of text with internal references and contested readings, where an agent that wants to engage seriously has to cite a specific passage rather than gesture at the corpus.
      </p>

      <p>
        A lot of what's here is salvaged from the falsafa.ai work: the citation block on every response, the rule that every page has a markdown sibling, the choice not to host any inference on the server. If you want to build something similar, the source is on <a href="https://github.com/CentreforCivilSociety-Academy/liberty-lighthouse" class="underline decoration-[var(--color-accent)]/40 hover:decoration-[var(--color-accent)]">GitHub</a> and the schema is at <a href="/AGENTS.md" class="underline decoration-[var(--color-accent)]/40 hover:decoration-[var(--color-accent)]">/AGENTS.md</a>.
      </p>

      <h3>What the agent gets back</h3>

      <p>Every response carries a citation block like this:</p>

      <pre class="text-[0.8125rem]" style="font-family: var(--monospace-font, ui-monospace, monospace);"><code>{`{
  "canonical_url": "https://liberty-lighthouse.vercel.app/glossary/msp/",
  "markdown_url":  "https://liberty-lighthouse.vercel.app/glossary/msp.md",
  "title":         "MSP",
  "kind":          "glossary",
  "last_modified": "2026-04-26"
}`}</code></pre>

      <p>
        An agent should quote the answer and cite <code>canonical_url</code> so the user lands on the human page. The <code>markdown_url</code> is for traversal to the next document, <code>kind</code> labels the shape (faq, glossary, video, topic, wiki, external_post, external_book_chapter), and <code>last_modified</code> exists so the agent can decide whether a cached answer is still current. Those five fields are the entire contract.
      </p>

      <p>
        The corpus is openly classical-liberal. On contested policy questions, an agent summarising it should say so rather than present the position as neutral consensus. The citation block helps with that, since every paraphrase points at a specific file you can open and verify against.
      </p>
    </div>
  </section>

