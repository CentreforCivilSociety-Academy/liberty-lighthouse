<script>
  // Copy the canonical /ai.md to the clipboard. The .md file is generated
  // post-build from the rendered page (see src/integrations/ai-page-markdown.ts),
  // so it always reflects the current page content.
  const btn = document.querySelector<HTMLButtonElement>('[data-md-copy]');
  const label = document.querySelector<HTMLSpanElement>('[data-md-copy-label]');
  btn?.addEventListener('click', async () => {
    if (!label) return;
    const original = label.textContent;
    try {
      const res = await fetch('/ai.md', { headers: { accept: 'text/markdown' } });
      if (!res.ok) throw new Error(`HTTP ${res.status}`);
      const text = await res.text();
      await navigator.clipboard.writeText(text);
      label.textContent = 'Copied';
    } catch {
      label.textContent = 'Failed';
    }
    setTimeout(() => {
      if (label) label.textContent = original ?? 'Copy';
    }, 1800);
  });
</script>
