---
import PageLayout from '../layouts/PageLayout.astro';
import Button from '../components/ui/Button.astro';
---

<PageLayout title="Page Not Found" description="The page you're looking for doesn't exist.">
  <div class="max-w-[var(--content-max-width)] mx-auto px-[var(--spacing-lg)] py-[var(--spacing-3xl)] text-center">
    <p class="text-[5rem] font-[800] text-[var(--color-border-default)] mb-[var(--spacing-md)]" style="font-family: var(--font-display);">404</p>
    <h1 class="text-[1.75rem] font-[600] text-[var(--color-text-primary)] mb-[var(--spacing-sm)]">Page not found</h1>
    <p class="text-[1.0625rem] text-[var(--color-text-secondary)] mb-[var(--spacing-xl)] max-w-[24rem] mx-auto">
      The page you're looking for doesn't exist or has been moved.
    </p>
    <div class="flex gap-[var(--spacing-md)] justify-center">
      <Button href="/" variant="primary" size="md">Go Home</Button>
      <Button href="/search/" variant="secondary" size="md">Search</Button>
    </div>
  </div>
</PageLayout>
