---
import Button from '../ui/Button.astro';
---

<section class="hero-folio relative bg-[var(--color-bg-dark)] overflow-hidden">
  <!-- Subtle grain texture overlay -->
  <div class="absolute inset-0 opacity-[0.03]" style="background-image: url('data:image/svg+xml,%3Csvg viewBox=%220 0 256 256%22 xmlns=%22http://www.w3.org/2000/svg%22%3E%3Cfilter id=%22noise%22%3E%3CfeTurbulence type=%22fractalNoise%22 baseFrequency=%220.9%22 numOctaves=%224%22 stitchTiles=%22stitch%22/%3E%3C/filter%3E%3Crect width=%22100%25%22 height=%22100%25%22 filter=%22url(%23noise)%22/%3E%3C/svg%3E'); background-size: 256px 256px;"></div>

  <!-- Warm horizon glow (atmospheric, bottom edge) -->
  <div class="hero-horizon absolute bottom-0 left-0 right-0 h-[45%] pointer-events-none" aria-hidden="true"></div>

  <!-- Content -->
  <div class="relative z-10 max-w-[var(--content-max-width)] mx-auto px-[var(--spacing-lg)] py-[var(--spacing-lg)] md:py-[2.5rem] lg:py-[3rem] text-center">
    <div class="max-w-[52rem] mx-auto">
      <!-- Eyebrow label -->
      <p class="hero-eyebrow text-[0.75rem] md:text-[0.8125rem] font-[600] uppercase tracking-[0.14em] text-[var(--color-accent)] mb-[var(--spacing-lg)] fade-up"
         style="font-family: var(--font-body);">
        A Classical Liberal Resource
      </p>

      <!-- Display title -->
      <h1
        class="hero-title text-[clamp(2rem,5vw,3.5rem)] font-[800] tracking-[-0.025em] leading-[1.05] text-[var(--color-text-on-dark)] mb-[var(--spacing-xl)] fade-up fade-up-delay-1"
        style="font-family: var(--font-display); font-optical-sizing: auto; text-wrap: balance;"
      >
        Liberty Lighthouse
      </h1>

      <!-- Ornamental rule -->
      <div class="hero-rule flex items-center justify-center gap-[0.75rem] mb-[var(--spacing-xl)] fade-up fade-up-delay-1" aria-hidden="true">
        <span class="hero-rule-line block h-[1px] w-[3.5rem] md:w-[5rem] bg-[var(--color-accent)] origin-left"></span>
        <span class="block w-[5px] h-[5px] rotate-45 bg-[var(--color-accent)] opacity-80"></span>
        <span class="hero-rule-line block h-[1px] w-[3.5rem] md:w-[5rem] bg-[var(--color-accent)] origin-right"></span>
      </div>

      <!-- Subtitle -->
      <p class="text-[1.0625rem] md:text-[1.1875rem] text-[var(--color-text-on-dark)] opacity-60 leading-[1.7] mb-[var(--spacing-xl)] max-w-[38rem] mx-auto fade-up fade-up-delay-2"
         style="font-family: var(--font-body); text-wrap: pretty;">
        Understanding India's policy landscape through curated FAQs, video curricula, and guided syllabi. Ideas that advance freedom, markets, and the rule of law.
      </p>

      <!-- CTA -->
      <div class="fade-up fade-up-delay-3">
        <Button href="/topics/" variant="primary" size="lg">
          Explore Topics
          <span aria-hidden="true">&rarr;</span>
        </Button>
      </div>
    </div>
  </div>
</section>

<style>
  /* Warm horizon glow — atmospheric dawn at bottom edge */
  .hero-horizon {
    background: radial-gradient(
      ellipse 100% 80% at 50% 100%,
      rgba(196, 112, 60, 0.05) 0%,
      rgba(196, 112, 60, 0.02) 40%,
      transparent 70%
    );
  }

  /* Ornamental rule draw-in animation */
  .hero-rule-line {
    animation: ruleDrawIn 600ms cubic-bezier(0.16, 1, 0.3, 1) both;
    animation-delay: 400ms;
    transform: scaleX(0);
  }

  @keyframes ruleDrawIn {
    from { transform: scaleX(0); opacity: 0; }
    to   { transform: scaleX(1); opacity: 1; }
  }

  /* Stagger: fade-up-delay-3 for CTA */
  :global(.fade-up-delay-3) {
    animation-delay: 300ms;
  }

  /* Accessibility: disable animations for reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .hero-rule-line {
      animation: none !important;
      transform: scaleX(1);
      opacity: 1;
    }
  }
</style>
