---
import Button from '../ui/Button.astro';
---

<section class="bg-[var(--color-bg-section)]">
  <div class="max-w-[var(--content-max-width)] mx-auto px-[var(--spacing-lg)] py-[var(--spacing-3xl)]">
    <div class="max-w-[var(--prose-max-width)] mx-auto text-center fade-up">
      <h2 class="text-[1.5rem] md:text-[1.75rem] font-[600] text-[var(--color-text-primary)] mb-[var(--spacing-md)]">
        About Liberty Lighthouse
      </h2>
      <p class="text-[1.0625rem] text-[var(--color-text-secondary)] leading-relaxed mb-[var(--spacing-xl)]">
        Liberty Lighthouse is a project of the Centre for Civil Society, one of India's leading think tanks advancing classical liberal ideas. We make policy research accessible through clear explanations, curated video content, and structured learning paths — all grounded in the principles of individual liberty, free markets, and limited government.
      </p>
      <Button href="/about/" variant="secondary" size="md">
        Learn More
      </Button>
    </div>
  </div>
</section>
