---
const currentYear = new Date().getFullYear();
---

<footer class="bg-[var(--color-bg-dark)] text-[var(--color-text-on-dark)]" role="contentinfo">
  <div class="max-w-[var(--content-max-width)] mx-auto px-[var(--spacing-lg)] py-[var(--spacing-2xl)]">

    <div class="grid grid-cols-1 md:grid-cols-3 gap-[var(--spacing-2xl)]">

      <!-- Brand -->
      <div>
        <p class="text-[1.125rem] font-[600] mb-[var(--spacing-sm)]" style="font-family: var(--font-display);">
          Liberty Lighthouse
        </p>
        <p class="text-[0.875rem] text-[var(--color-text-on-dark)] opacity-70 leading-relaxed max-w-[20rem]">
          A classical liberal resource for understanding India's policy landscape. A project of the Centre for Civil Society.
        </p>
      </div>

      <!-- Navigation -->
      <div>
        <p class="text-[0.75rem] font-semibold uppercase tracking-[0.08em] text-[var(--color-text-on-dark)] opacity-50 mb-[var(--spacing-md)]">
          Navigate
        </p>
        <nav aria-label="Footer navigation">
          <ul class="space-y-[var(--spacing-sm)] list-none p-0">
            <li><a href="/topics/" class="text-[0.875rem] text-[var(--color-text-on-dark)] opacity-80 hover:opacity-100 no-underline transition-opacity duration-[var(--duration-fast)]">Topics</a></li>
            <li><a href="/glossary/" class="text-[0.875rem] text-[var(--color-text-on-dark)] opacity-80 hover:opacity-100 no-underline transition-opacity duration-[var(--duration-fast)]">Glossary</a></li>
            <li><a href="/about/" class="text-[0.875rem] text-[var(--color-text-on-dark)] opacity-80 hover:opacity-100 no-underline transition-opacity duration-[var(--duration-fast)]">About</a></li>
            <li><a href="/search/" class="text-[0.875rem] text-[var(--color-text-on-dark)] opacity-80 hover:opacity-100 no-underline transition-opacity duration-[var(--duration-fast)]">Search</a></li>
            <li><a href="/privacy/" class="text-[0.875rem] text-[var(--color-text-on-dark)] opacity-80 hover:opacity-100 no-underline transition-opacity duration-[var(--duration-fast)]">Privacy</a></li>
          </ul>
        </nav>
      </div>

      <!-- CCS -->
      <div>
        <p class="text-[0.75rem] font-semibold uppercase tracking-[0.08em] text-[var(--color-text-on-dark)] opacity-50 mb-[var(--spacing-md)]">
          Centre for Civil Society
        </p>
        <ul class="space-y-[var(--spacing-sm)] list-none p-0">
          <li><a href="https://ccs.in" class="text-[0.875rem] text-[var(--color-text-on-dark)] opacity-80 hover:opacity-100 no-underline transition-opacity duration-[var(--duration-fast)]" target="_blank" rel="noopener noreferrer">ccs.in</a></li>
        </ul>
      </div>

    </div>

    <!-- Divider + Copyright -->
    <div class="mt-[var(--spacing-2xl)] pt-[var(--spacing-lg)] border-t border-[var(--color-text-on-dark)]/10 flex flex-wrap items-center justify-between gap-[var(--spacing-md)]">
      <p class="text-[0.75rem] text-[var(--color-text-on-dark)] opacity-70">
        &copy; {currentYear} Centre for Civil Society. All rights reserved. Built with 💛 by <a href="https://meetadnan.com" class="underline text-[var(--color-accent)] hover:text-[var(--color-accent-soft)] transition-colors duration-[var(--duration-fast)]" target="_blank" rel="noopener noreferrer">Adnan</a>.
      </p>
      <button
        type="button"
        data-cookie-settings
        class="text-[0.75rem] text-[var(--color-text-on-dark)] opacity-70 hover:opacity-100 underline underline-offset-2 transition-opacity duration-[var(--duration-fast)] bg-transparent border-0 cursor-pointer p-0"
      >
        Cookie settings
      </button>
    </div>

  </div>
</footer>

<script>
  import { openCookieConsent } from './CookieConsent';
  document.querySelectorAll('[data-cookie-settings]').forEach((btn) => {
    btn.addEventListener('click', () => openCookieConsent());
  });
</script>
