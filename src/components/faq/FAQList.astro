---
import { getSlugFromId } from '../../lib/collections';

interface FAQItem {
  id: string;
  data: {
    question: string;
    topic: string;
    order: number;
  };
}

interface Props {
  faqs: FAQItem[];
  topicSlug: string;
}

const { faqs, topicSlug } = Astro.props;
---

<div class="space-y-[var(--spacing-sm)]">
  {faqs.map((faq) => (
    <a
      href={`/topics/${topicSlug}/faq/${getSlugFromId(faq.id)}/`}
      class="block p-[var(--spacing-lg)] bg-[var(--color-bg-card)] border border-[var(--color-border-default)] rounded-[var(--radius-md)] no-underline hover:border-[var(--color-border-strong)] hover:shadow-[var(--shadow-sm)] transition-all duration-[var(--duration-normal)] group"
    >
      <p class="text-[1.0625rem] font-medium text-[var(--color-text-primary)] group-hover:text-[var(--color-primary)] transition-colors duration-[var(--duration-fast)]">
        {faq.data.question}
      </p>
    </a>
  ))}
</div>
