---
interface Props {
  topicSlug: string;
  faqCount: number;
  videoCount: number;
  hasSyllabus: boolean;
  activeTab?: 'faq' | 'videos' | 'syllabus';
}

const { topicSlug, faqCount, videoCount, hasSyllabus, activeTab = 'faq' } = Astro.props;

const tabs = [
  { id: 'faq', label: 'FAQ', count: faqCount, show: faqCount > 0, href: `/topics/${topicSlug}/faq/` },
  { id: 'videos', label: 'Videos', count: videoCount, show: videoCount > 0, href: `/topics/${topicSlug}/videos/` },
  { id: 'syllabus', label: 'Syllabus', count: null, show: hasSyllabus, href: `/topics/${topicSlug}/syllabus/` },
].filter((tab) => tab.show);
---

<nav aria-label="Resource types" class="mb-[var(--spacing-2xl)]">
  <div class="flex gap-0 border-b border-[var(--color-border-default)]" role="tablist">
    {tabs.map((tab) => (
      <a
        href={tab.href}
        role="tab"
        aria-selected={activeTab === tab.id ? 'true' : 'false'}
        class:list={[
          'relative px-[var(--spacing-lg)] py-[var(--spacing-md)] text-[0.9375rem] font-medium no-underline transition-colors duration-[var(--duration-fast)]',
          activeTab === tab.id
            ? 'text-[var(--color-primary)]'
            : 'text-[var(--color-text-tertiary)] hover:text-[var(--color-text-primary)]',
        ]}
      >
        {tab.label}
        {tab.count !== null && (
          <span class="ml-[var(--spacing-xs)] text-[0.75rem] text-[var(--color-text-muted)]">
            {tab.count}
          </span>
        )}
        {activeTab === tab.id && (
          <span class="absolute bottom-0 left-0 right-0 h-[2px] bg-[var(--color-accent)]"></span>
        )}
      </a>
    ))}
  </div>
</nav>
