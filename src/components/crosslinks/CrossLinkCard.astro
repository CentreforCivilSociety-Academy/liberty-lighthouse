---
import ContentTypeBadge from '../ui/ContentTypeBadge.astro';
import { getContentUrl } from '../../lib/collections';

interface Props {
  type: 'faq' | 'video' | 'syllabus';
  title: string;
  topic: string;
  id: string;
  description?: string;
}

const { type, title, topic, id, description } = Astro.props;
const url = getContentUrl(type, topic, id);
---

<a
  href={url}
  class="flex gap-[var(--spacing-md)] p-[var(--spacing-md)] bg-[var(--color-bg-section)] rounded-[var(--radius-md)] no-underline hover:bg-[var(--color-bg-elevated)] transition-colors duration-[var(--duration-fast)] group border border-transparent hover:border-[var(--color-border-default)]"
>
  <div class="flex-1 min-w-0">
    <div class="flex items-center gap-[var(--spacing-xs)] mb-[var(--spacing-xs)]">
      <ContentTypeBadge type={type} />
    </div>
    <p class="text-[0.9375rem] font-medium text-[var(--color-text-primary)] group-hover:text-[var(--color-primary)] transition-colors truncate">
      {title}
    </p>
    {description && (
      <p class="text-[0.8125rem] text-[var(--color-text-tertiary)] line-clamp-1 mt-[var(--spacing-xs)]">{description}</p>
    )}
  </div>
  <div class="flex-shrink-0 self-center text-[var(--color-text-muted)] group-hover:text-[var(--color-primary)] transition-colors">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
      <path d="M9 18l6-6-6-6" />
    </svg>
  </div>
</a>
