---
import { getSlugFromId } from '../../lib/collections';
import Badge from '../ui/Badge.astro';

interface Props {
  id: string;
  title: string;
  topic: string;
  moduleNumber: number;
  estimatedTime?: string;
  description: string;
}

const { id, title, topic, moduleNumber, estimatedTime, description } = Astro.props;
const slug = getSlugFromId(id);
---

<a
  href={`/topics/${topic}/syllabus/${slug}/`}
  class="flex gap-[var(--spacing-lg)] p-[var(--spacing-lg)] bg-[var(--color-bg-card)] border border-[var(--color-border-default)] rounded-[var(--radius-md)] no-underline hover:border-[var(--color-border-strong)] hover:shadow-[var(--shadow-sm)] transition-all duration-[var(--duration-normal)] group"
>
  <!-- Module Number -->
  <div class="flex-shrink-0 w-10 h-10 rounded-full bg-[var(--color-accent)]/10 flex items-center justify-center">
    <span class="text-[0.875rem] font-bold text-[var(--color-accent-text)]">{moduleNumber}</span>
  </div>

  <!-- Content -->
  <div class="flex-1 min-w-0">
    <div class="flex items-center gap-[var(--spacing-sm)] mb-[var(--spacing-xs)]">
      <h3 class="text-[1rem] font-[600] text-[var(--color-text-primary)] group-hover:text-[var(--color-primary)] transition-colors truncate normal-case tracking-normal" style="font-family: var(--font-display);">
        {title}
      </h3>
      {estimatedTime && (
        <span class="flex-shrink-0 text-[0.75rem] text-[var(--color-text-muted)]">{estimatedTime}</span>
      )}
    </div>
    <p class="text-[0.875rem] text-[var(--color-text-secondary)] line-clamp-2">{description}</p>
  </div>

  <!-- Arrow -->
  <div class="flex-shrink-0 self-center text-[var(--color-text-muted)] group-hover:text-[var(--color-primary)] transition-colors">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
      <path d="M9 18l6-6-6-6" />
    </svg>
  </div>
</a>
